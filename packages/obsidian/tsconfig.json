{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2020",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@archivex/core": ["../core/src"],
      "@archivex/ui": ["../ui/src"],
      "@archivex/ui/*": ["../ui/src/*"]
    }
  },
  "include": ["src/**/*.ts", "../ui/src/**/*.svelte"]
}
